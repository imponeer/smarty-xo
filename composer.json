{
    "name": "imponeer/smarty-xo",
    "description": "Smarty template engine plugins collections based on ideas for plugins from XOOPS",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "smarty/smarty": ">=5.0"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Raimondas Rimkevičius",
            "email": "github@mekdrop.name"
        }
    ],
    "autoload": {
        "psr-4": {
            "Imponeer\\Smarty\\Extensions\\XO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imponeer\\Smarty\\Extensions\\XO\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "smarty",
        "xoops",
        "links",
        "counter",
        "pagination",
        "smarty-plugins"
    ],
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "phpstan": "phpstan analyse -c phpstan.neon.dist",
        "phpcs": "phpcs --standard=phpcs.xml.dist src tests"
    },
    "config": {
        "preferred-install": {
            "phpstan/phpstan": "source"
        }
    }
}
