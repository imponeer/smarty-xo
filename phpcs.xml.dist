<?xml version="1.0"?>
<ruleset name="Smarty XO Coding Standards">
    <description>Project-level PHPCS ruleset.</description>

    <file>src</file>
    <file>tests</file>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="parallel" value="4"/>

    <rule ref="PSR12"/>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>var/*</exclude-pattern>
</ruleset>
